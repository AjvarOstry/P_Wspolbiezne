<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TP.ConcurrentProgramming.Presentation.ViewModel"
        x:Class="TP.ConcurrentProgramming.AvaloniaUI.StartWindow"
        x:DataType="vm:StartWindowViewModel"
        Title="Starting Configuration"
        SizeToContent="WidthAndHeight">
    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="200">

            <TextBlock Text="Liczba kulek:" 
                       HorizontalAlignment="Center"/>

            <Slider x:Name="BallsSlider"
        Minimum="{Binding MinBalls}"
        Maximum="{Binding MaxBalls}"
        Value="{Binding SelectedNumberOfBalls, Mode=TwoWay}"
        TickFrequency="1"
        IsSnapToTickEnabled="True"/>

<!-- To poniżej też musi używać właściwości z ViewModelu -->
<TextBlock Text="{Binding SelectedNumberOfBalls}" 
           HorizontalAlignment="Center"/>

            <Button Content="Start"
                    Click="Start_Simulation"
                    Height="40"
                    Margin="20"/>
        </StackPanel>
    </Grid>
</Window>